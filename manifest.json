{
  "manifest_version": 3,
  "name": "DoctorAI",
  "version": "1.0",
  "description": "Your ultimate AI agent extension with Voice Command, Screen Capture, Ambient Listening, and more.",
  "action": {
    "default_icon": {
      "16": "assets/icon.png",
      "48": "assets/icon.png",
      "128": "assets/icon.png"
    }
  },
  "side_panel": {
    "default_path": "html/popup.html"
  },
  "permissions": [
    "tabs",
    "activeTab",
    "storage",
    "tabCapture",
    "desktopCapture",
    "scripting",
    "offscreen",
    "microphone",
    "sidePanel"
  ],
  "host_permissions": [
    "<all_urls>",
    "http://localhost:11434/*",
    "http://localhost:8080/*",
    "https://router.huggingface.co/*",
    "https://shazam.p.rapidapi.com/*"
  ],
  "background": {
    "service_worker": "js/background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["js/content.js"]
    }
  ],
  "icons": {
    "16": "assets/icon.png",
    "48": "assets/icon.png",
    "128": "assets/icon.png"
  }
}
